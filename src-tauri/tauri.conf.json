{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Friday",
  "version": "0.1.0",
  "identifier": "com.joris.friday",
  "build": {
    "beforeDevCommand": "node ./scripts/pkg-run.js dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node ./scripts/pkg-run.js build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Friday",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "host": "oauth2redirect",
          "schemes": ["m6loapp"]
        }
      ]
    }
  }
}
